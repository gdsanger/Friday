# ── Django ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database ──────────────────────────────────────────────────
# Native PostgreSQL — create DB with: createdb friday
DATABASE_URL=postgresql://localhost/friday

# ── Redis / Celery ────────────────────────────────────────────
# Native Redis — start with: redis-server
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Azure / MSAL (SSO + Graph API) ───────────────────────────
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id-or-common
AZURE_REDIRECT_URI=http://localhost:8000/accounts/azure/callback/

# Graph API webhook — must be publicly reachable HTTPS URL
# Local dev: use ngrok → https://<id>.ngrok.io/api/mail/webhook/
GRAPH_WEBHOOK_URL=https://your-domain.com/api/mail/webhook/

# ── Mail Service (separate from SSO) ─────────────────────────
# Separate Azure App Registration for Mail (Client Credentials Flow)
MAIL_AZURE_CLIENT_ID=your-mail-app-client-id
MAIL_AZURE_CLIENT_SECRET=your-mail-app-client-secret
MAIL_AZURE_TENANT_ID=your-azure-tenant-id

# System Mailbox
MAIL_FROM_ADDRESS=friday@isartec.de
MAIL_FROM_NAME=Friday
MAIL_SHARED_MAILBOX=friday@isartec.de

# Site URL for email links
SITE_URL=http://localhost:8011

# ── AI Providers (global — stored encrypted in DB after first run) ──
# Used only by: python manage.py seed_ai_config
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=claude

# ── Security ──────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── Media / Static ────────────────────────────────────────────
MEDIA_URL=/media/
STATIC_URL=/static/
